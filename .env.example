# simgit environment configuration
# Copy this file to .env and fill in your values.

# LLM API key — used by the real-agent harness (tests/real_agent_harness.py) only.
# Accepts either variable name; SIMGIT_LLM_API_KEY takes precedence.
SIMGIT_LLM_API_KEY=

# Daemon state directory — socket and session state are created here.
SIMGIT_STATE_DIR=/tmp/simgit-dev

# Path to the daemon control socket — set this in client shells.
SIMGIT_SOCKET=/tmp/simgit-dev/control.sock

# Repository root — directory the daemon manages.
SIMGIT_REPO=

# Metrics (optional)
SIMGIT_METRICS_ENABLED=0
SIMGIT_METRICS_ADDR=127.0.0.1:9100

# OTLP tracing endpoint (optional)
# SIMGIT_OTLP_ENDPOINT=http://127.0.0.1:4317
